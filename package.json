{
  "name": "@tetsuo-ai/agenc-indexer",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Self-hostable read-model indexer for the AgenC marketplace protocol on Solana: gPA snapshot polling -> SQLite -> versioned REST + SSE, including the four SDK-documented explorer endpoints.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetsuo-ai/agenc-indexer.git"
  },
  "homepage": "https://github.com/tetsuo-ai/agenc-indexer#readme",
  "bugs": {
    "url": "https://github.com/tetsuo-ai/agenc-indexer/issues"
  },
  "keywords": [
    "agenc",
    "solana",
    "indexer",
    "marketplace",
    "read-model"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/__tests__/*.test.ts",
    "test:coverage": "c8 node --import tsx --test src/__tests__/*.test.ts && npm run coverage:gate",
    "coverage:gate": "c8 report --check-coverage --per-file --lines 95 --include src/server.ts --include src/store.ts --exclude-after-remap"
  },
  "dependencies": {
    "@solana/kit": "^6.9.0",
    "@solana/program-client-core": "^6.4.0",
    "@solana/web3.js": "^1.98.4",
    "@tetsuo-ai/marketplace-sdk": "^0.12.0",
    "better-sqlite3": "^12.8.0",
    "bs58": "^6.0.0"
  },
  "comment:overrides": "web3.js' jayson dependency only uses uuid.v4 and standard ws APIs. These scoped updates retain those APIs, include the uuid bounds-check fix, and avoid an invalid ws7 optional-peer tree beside Solana's ws8 stack.",
  "overrides": {
    "jayson": {
      "uuid": "11.1.1",
      "ws": "8.21.0"
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "c8": "^11.0.0",
    "esbuild": "^0.25.9",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.23.1"
  }
}
